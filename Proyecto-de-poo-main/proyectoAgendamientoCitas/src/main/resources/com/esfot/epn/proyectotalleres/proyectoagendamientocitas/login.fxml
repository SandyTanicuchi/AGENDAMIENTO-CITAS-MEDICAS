<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esfot.epn.proyectotalleres.proyectoagendamientocitas.LoginController"
      stylesheets="@css/login.css"
      prefWidth="950" prefHeight="620">

    <!-- PANEL IZQUIERDO: Imagen + texto -->
    <StackPane styleClass="panel-left" prefWidth="480">
        <VBox alignment="BOTTOM_LEFT" styleClass="panel-left-overlay">
            <padding><Insets top="40" bottom="60" left="48" right="48"/></padding>
            <Label text="Gestión de Citas" styleClass="brand-title"/>
            <Label text="Sistema Médico" styleClass="brand-sub"/>
            <Region prefHeight="48"/>
            <Label text="Cuidamos tu salud," styleClass="hero-title"/>
            <Label text="organizamos tu tiempo." styleClass="hero-title"/>
            <Region prefHeight="18"/>
            <Label text="Inicia sesión para acceder a tu panel y gestionar tus citas de manera sencilla."
                   styleClass="hero-desc" wrapText="true" maxWidth="380"/>
            <Region prefHeight="40"/>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="📅" styleClass="bullet-icon"/>
                <VBox spacing="2">
                    <Label text="Gestiona tus citas" styleClass="bullet-title"/>
                    <Label text="Programa y organiza tus consultas." styleClass="bullet-desc"/>
                </VBox>
            </HBox>
            <Region prefHeight="18"/>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="👥" styleClass="bullet-icon"/>
                <VBox spacing="2">
                    <Label text="Pacientes" styleClass="bullet-title"/>
                    <Label text="Consulta el historial y datos de tus pacientes." styleClass="bullet-desc"/>
                </VBox>
            </HBox>
            <Region prefHeight="18"/>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="📊" styleClass="bullet-icon"/>
                <VBox spacing="2">
                    <Label text="Agenda inteligente" styleClass="bullet-title"/>
                    <Label text="Optimiza tu tiempo y mejora la atención." styleClass="bullet-desc"/>
                </VBox>
            </HBox>
        </VBox>
    </StackPane>

    <!-- PANEL DERECHO: Formulario -->
    <VBox styleClass="panel-right" HBox.hgrow="ALWAYS" alignment="CENTER">
        <padding><Insets top="60" bottom="60" left="60" right="60"/></padding>

        <VBox maxWidth="400" spacing="0" alignment="CENTER_LEFT">
            <Label text="👤" styleClass="user-icon" alignment="CENTER" maxWidth="Infinity"/>
            <Region prefHeight="18"/>
            <Label text="Iniciar sesión" styleClass="form-title" alignment="CENTER" maxWidth="Infinity"/>
            <Region prefHeight="4"/>
            <Label text="Accede a tu cuenta para continuar" styleClass="form-sub" alignment="CENTER" maxWidth="Infinity"/>

            <Region prefHeight="42"/>

            <Label text="Rol" styleClass="field-label"/>
            <Region prefHeight="8"/>
            <ComboBox fx:id="comboRol" promptText="Seleccione su rol"
                      styleClass="input-field" maxWidth="Infinity"/>

            <Region prefHeight="22"/>

            <Label text="Usuario" styleClass="field-label"/>
            <Region prefHeight="8"/>
            <TextField fx:id="txtUsuario" promptText="Ingrese su usuario"
                       styleClass="input-field" maxWidth="Infinity"/>

            <Region prefHeight="22"/>

            <Label text="Contraseña" styleClass="field-label"/>
            <Region prefHeight="8"/>
            <PasswordField fx:id="txtPassword" promptText="••••••••"
                           styleClass="input-field" maxWidth="Infinity"/>

            <Region prefHeight="10"/>
            <Label fx:id="lblError" styleClass="error-label" visible="false" wrapText="true"/>

            <Region prefHeight="32"/>
            <Button text="  Iniciar sesión" onAction="#handleLogin"
                    styleClass="btn-login" maxWidth="Infinity"/>
        </VBox>
    </VBox>

</HBox>