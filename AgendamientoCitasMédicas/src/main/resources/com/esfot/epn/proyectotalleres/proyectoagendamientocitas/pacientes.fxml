<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" stylesheets="@css/global.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esfot.epn.proyectotalleres.proyectoagendamientocitas.PacientesController">

    <!-- â•â•â• HEADER (igual que dashboard) â•â•â• -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="header" BorderPane.alignment="CENTER_LEFT">
            <children>
                <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../img/logo.png" /></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="header-title" text="VitalSched" />
                        <Label styleClass="header-subtitle" text="Gestión de Pacientes" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <FontIcon iconColor="#93c5fd" iconLiteral="fas-user-injured" iconSize="20" />
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Modulo de Pacientes" />
                                <Label style="-fx-text-fill: #93c5fd; -fx-font-size: 11px;" text="Administración" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding><Insets left="20.0" right="20.0" /></padding>
        </HBox>
    </top>

    <!-- â•â•â• SIDEBAR IZQUIERDO â€” Formulario â•â•â• -->
    <left>
        <VBox prefWidth="370.0" spacing="0.0" style="-fx-background-color: #ffffff; -fx-border-color: transparent #e2e8f0 transparent transparent; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">

            <!-- TÃ­tulo secciÃ³n -->
            <VBox style="-fx-padding: 20px 20px 15px 20px; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0; -fx-background-color: #f8fafc;">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <FontIcon iconColor="#3b82f6" iconLiteral="fas-id-card" iconSize="18" />
                    <Label style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 16px;" text="Información del Paciente" />
                </HBox>
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 4 0 0 0;" text="Complete los campos del paciente" />
            </VBox>

            <!-- Campos del formulario -->
            <VBox spacing="12.0" style="-fx-padding: 18px 20px;">

                <HBox spacing="12.0">
                    <VBox prefWidth="80.0" spacing="5.0">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="ID" />
                        <TextField fx:id="txtId" editable="false" promptText="Auto" style="-fx-background-color: #ffffff; -fx-text-fill: #64748b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Cédula:" />
                        <TextField fx:id="txtCedula" promptText="0000000000" style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                    </VBox>
                </HBox>

                <HBox spacing="12.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Nombres" />
                        <TextField fx:id="txtNombre" promptText="Nombres" style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Apellidos" />
                        <TextField fx:id="txtApellido" promptText="Apellidos" style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                    </VBox>
                </HBox>

                <HBox spacing="12.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Teléfono:" />
                        <TextField fx:id="txtTelf" promptText="09XXXXXXXX" style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Estado" />
                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity" promptText="Estado..." style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 13px;" />
                    </VBox>
                </HBox>

                <VBox spacing="5.0">
                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Correo Electronico:" />
                    <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com" style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Dirección" />
                    <TextField fx:id="txtDireccion" promptText="Calle, número, ciudad..." style="-fx-background-color: #ffffff; -fx-text-fill: #1e293b; -fx-border-color: #cbd5e1; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 8 10; -fx-font-size: 13px;" />
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Imagen decorativa -->
            <HBox alignment="CENTER" style="-fx-padding: 0 0 10 0;">
                <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true" style="-fx-opacity: 0.5;">
                    <image><Image url="@../img/doc.jpg" /></image>
                </ImageView>
            </HBox>

            <!-- Botones de acciÃ³n -->
            <VBox spacing="8.0" style="-fx-padding: 15px 20px 20px 20px; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 1 0 0 0; -fx-background-color: #f8fafc;">
                <HBox spacing="8.0">
                    <Button fx:id="btnInsertar" maxWidth="Infinity" mnemonicParsing="false" onAction="#guardarPaciente" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 0; -fx-font-size: 13px;" text="Guardar" HBox.hgrow="ALWAYS">
                        <graphic><FontIcon iconColor="white" iconLiteral="fas-save" iconSize="13" /></graphic>
                    </Button>
                    <Button fx:id="btnModificar" maxWidth="Infinity" mnemonicParsing="false" onAction="#modificarPaciente" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 0; -fx-font-size: 13px;" text="Modificar" HBox.hgrow="ALWAYS">
                        <graphic><FontIcon iconColor="white" iconLiteral="fas-edit" iconSize="13" /></graphic>
                    </Button>
                </HBox>
                <HBox spacing="8.0">
                    <Button fx:id="btnLimpiar" maxWidth="Infinity" mnemonicParsing="false" onAction="#limpiarCampos" style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 0; -fx-font-size: 13px;" text="Limpiar" HBox.hgrow="ALWAYS">
                        <graphic><FontIcon iconColor="white" iconLiteral="fas-broom" iconSize="13" /></graphic>
                    </Button>
                    <Button fx:id="btnEliminar" maxWidth="Infinity" mnemonicParsing="false" onAction="#eliminarPaciente" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 0; -fx-font-size: 13px;" text="Eliminar" HBox.hgrow="ALWAYS">
                        <graphic><FontIcon iconColor="white" iconLiteral="fas-trash-alt" iconSize="13" /></graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- â•â•â• CONTENIDO CENTRAL â€” Tabla â•â•â• -->
    <center>
        <VBox spacing="15.0" style="-fx-background-color: #f9fafb; -fx-padding: 25px;">

            <!-- Sub-header de secciÃ³n -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="3.0">
                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Listado de Pacientes Registrados" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" text="Haga clic en una fila para seleccionar y editar un paciente" />
                </VBox>
            </HBox>

            <!-- Tabla -->
            <VBox style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 10, 0, 0, 4); -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablePacientes" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="55.0" text="ID" />
                        <TableColumn fx:id="colCedula" prefWidth="120.0" text="Cedula" />
                        <TableColumn fx:id="colNombre" prefWidth="155.0" text="Nombres" />
                        <TableColumn fx:id="colApellido" prefWidth="155.0" text="Apellidos" />
                        <TableColumn fx:id="colTelefono" prefWidth="115.0" text="Teléfono" />
                        <TableColumn fx:id="colCorreo" prefWidth="190.0" text="Correo" />
                        <TableColumn fx:id="colDireccion" prefWidth="160.0" text="Dirección" />
                        <TableColumn fx:id="colEstado" prefWidth="75.0" text="Estado" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- â•â•â• FOOTER â•â•â• -->
    <bottom>
        <HBox prefHeight="32.0" styleClass="footer" BorderPane.alignment="CENTER">
            <Label styleClass="footer-text" text="VitalSched © 2026 |  Modulo de Pacientes| Todos los derechos reservados." />
        </HBox>
    </bottom>

</BorderPane>
