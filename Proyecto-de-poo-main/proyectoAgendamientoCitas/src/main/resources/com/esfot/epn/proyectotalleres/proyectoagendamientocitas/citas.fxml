<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo1.controlador.CitasController"
      stylesheets="@css/citas.css"
      prefWidth="850" prefHeight="680"
      minWidth="750" minHeight="600"
      spacing="0">

    <!-- TÍTULO -->
    <VBox styleClass="header" alignment="CENTER">
        <padding><Insets top="26" bottom="26"/></padding>
        <Label text="Gestión de Citas Médicas" styleClass="titulo"/>
    </VBox>

    <!-- FORMULARIO -->
    <GridPane styleClass="formulario" hgap="14" vgap="18">
        <padding><Insets top="28" bottom="28" left="50" right="50"/></padding>
        <columnConstraints>
            <ColumnConstraints minWidth="90" prefWidth="90"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
        <HBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="12">
            <TextField fx:id="txtId" prefWidth="150" styleClass="input-field"/>
            <Button text="Buscar" onAction="#handleBuscar" styleClass="btn-buscar"/>
        </HBox>

        <Label text="Paciente:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label"/>
        <TextField fx:id="txtPaciente" styleClass="input-field" maxWidth="Infinity"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Médico:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label"/>
        <TextField fx:id="txtMedico" styleClass="input-field" maxWidth="Infinity"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label"/>
        <TextField fx:id="txtFecha" styleClass="input-field" maxWidth="Infinity"
                   promptText="DD/MM/AAAA"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Hora:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label"/>
        <TextField fx:id="txtHora" styleClass="input-field" maxWidth="Infinity"
                   promptText="HH:MM"
                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label"/>
        <ComboBox fx:id="comboEstado" styleClass="input-field" maxWidth="Infinity"
                  GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label"/>
        <TextArea fx:id="txtMotivo" prefHeight="70" wrapText="true" maxWidth="Infinity"
                  promptText="Motivo de la cita..."
                  styleClass="input-field"
                  GridPane.columnIndex="1" GridPane.rowIndex="6"/>

    </GridPane>

    <!-- BOTONES -->
    <HBox styleClass="botones" spacing="14" alignment="CENTER">
        <padding><Insets top="16" bottom="16"/></padding>
        <Button text="Insertar"  onAction="#handleInsertar"  styleClass="btn-accion"/>
        <Button text="Modificar" onAction="#handleModificar" styleClass="btn-accion"/>
        <Button text="Mostrar"   onAction="#handleMostrar"   styleClass="btn-accion"/>
        <Button text="Eliminar"  onAction="#handleEliminar"  styleClass="btn-eliminar"/>
    </HBox>

    <!-- TABLA -->
    <TableView fx:id="tablaCitas" VBox.vgrow="ALWAYS" styleClass="tabla">
        <padding><Insets left="24" right="24" bottom="24"/></padding>
        <columns>
            <TableColumn fx:id="colId"       text="ID"          prefWidth="50"/>
            <TableColumn fx:id="colPaciente" text="Paciente"    prefWidth="140"/>
            <TableColumn fx:id="colMedico"   text="Médico"      prefWidth="140"/>
            <TableColumn fx:id="colFecha"    text="Fecha"       prefWidth="95"/>
            <TableColumn fx:id="colHora"     text="Hora"        prefWidth="70"/>
            <TableColumn fx:id="colEstado"   text="Estado"      prefWidth="100"/>
            <TableColumn fx:id="colMotivo"   text="Descripción" prefWidth="160"/>
        </columns>
    </TableView>

</VBox>